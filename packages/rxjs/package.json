{
  "name": "@telefunc/rxjs",
  "version": "0.1.0",
  "description": "RxJS Observable and Subject support for Telefunc — pass rxjs primitives transparently between client and server.",
  "homepage": "https://github.com/brillout/telefunc/tree/main/packages/rxjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brillout/telefunc.git",
    "directory": "packages/rxjs"
  },
  "license": "MIT",
  "telefunc": {
    "server": "@telefunc/rxjs/server",
    "client": "@telefunc/rxjs/client"
  },
  "type": "module",
  "sideEffects": ["./dist/server.js", "./dist/client.js"],
  "exports": {
    "./package.json": "./package.json",
    "./server": {
      "types": "./dist/server.d.ts",
      "worker": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "browser": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "telefunc": ">=0.2.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "telefunc": "workspace:*",
    "rxjs": "^7.8.0",
    "typescript": "^5.9.2"
  }
}
